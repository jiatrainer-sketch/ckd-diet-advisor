# ═══════════════════════════════════════════════════════════════════
# CKD Diet Advisor — environment variables
# ═══════════════════════════════════════════════════════════════════

# --- Client (exposed to browser bundle; anything VITE_* is public) ---
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=<your anon key>
# Optional: phone number shown on Screening page; if unset the button is hidden
VITE_CLINIC_PHONE=

# --- Server (Vercel env only, NEVER prefixed VITE_) ---
ANTHROPIC_API_KEY=sk-ant-...
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service role key>

# Comma-separated list of allowed origins for /api/*; leave empty in dev
ALLOWED_ORIGINS=https://your-domain.vercel.app,https://your-custom-domain.com

# Doctor dashboard — used by /api/doctor-auth
DOCTOR_PIN=<choose a long PIN>
# Random 32+ character string; used to sign short-lived doctor tokens
DOCTOR_SECRET=<openssl rand -base64 48>
